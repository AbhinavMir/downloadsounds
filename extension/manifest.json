{
  "manifest_version": 3,
  "name": "YTD DJ",
  "version": "0.2.0",
  "description": "Download YouTube audio as MP3 into AI-categorized DJ library folders.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "http://127.0.0.1:7531/*",
    "*://www.youtube.com/*",
    "https://raw.githubusercontent.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/watch*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "YTD DJ"
  }
}
